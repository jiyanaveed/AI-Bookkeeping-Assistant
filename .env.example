OPENAI_API_KEY=
COMPANIES_HOUSE_API_KEY=

# Local dev (default): SQLite + disk under UPLOAD_DIR.
DATABASE_URL=sqlite:///./app.db
UPLOAD_DIR=./data/uploads

# Production (Supabase Postgres on Render): use SQLAlchemy + psycopg3 URL, e.g.
# DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
# (Use the string from Supabase → Project Settings → Database; prefer pooler host for serverless.)

MAX_UPLOAD_MB=15
ADMIN_API_KEY=

# Supabase Storage — when BOTH are set, uploads go to this bucket (not local disk). Create bucket "Uploads" in dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=Uploads

# v1 demo auth uses email + password + DB-backed bearer sessions (see /v1/auth/*).
# Swap for OAuth/JWT in production; passwords stored as PBKDF2 hashes on users.password_hash.

# Static UI on Vercel: see web/env.example (PUBLIC_API_BASE build var only; no secrets there).
