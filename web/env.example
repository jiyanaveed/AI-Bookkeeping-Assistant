# Frontend (Vercel) — set in Project → Settings → Environment Variables
# Build-time only: embedded into web/js/runtime-config.js during `npm run vercel-build`.
#
# HTTPS origin of your FastAPI backend (no trailing slash). Not a secret.
# Required for production when the UI is on a different host than the API.
PUBLIC_API_BASE=https://your-api.example.com

# Do NOT put OpenAI keys, admin keys, or DB URLs here — those belong on the backend host only.
